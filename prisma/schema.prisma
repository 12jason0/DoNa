// 🟢 공유 전용 미리보기: shareId로 공유 링크 관리
model SharedCourse {
  id                 String   @id @default(cuid())
  templateCourseId   Int      @map("template_course_id")
  sharedByUserId     Int?     @map("shared_by_user_id")
  selectedPlaceIds   Int[]    @map("selected_place_ids") @default([]) // 완성 코스: 선택된 place_id 배열, 같이 고르기: []
  createdAt          DateTime @default(now()) @map("created_at")

  templateCourse     Course   @relation(fields: [templateCourseId], references: [id], onDelete: Cascade)

  @@index([id])
  @@index([templateCourseId])
  @@map("shared_courses")
}

// 🟢 AI 추천 1일 사용 횟수 추적 (등급별 한도: FREE 1회, BASIC 5회, PREMIUM 무제한)
model AiRecommendationUsage {
  id     Int      @id @default(autoincrement())
  userId Int      @map("user_id")
  usedAt DateTime @default(now()) @map("used_at")
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt])
  @@map("ai_recommendation_usages")
}

// 🟢 추천 피드백 (유저가 선택한 코스에 대한 만족도)
model RecommendationFeedback {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  courseId     Int      @map("course_id")
  rating       String   @db.VarChar(20)   // "GOOD" | "OK" | "BAD"
  context      String   @db.VarChar(50)   // "AI_RECOMMENDATION"
  matchScore   Float?   @map("match_score")
  matchReason  String?  @map("match_reason") @db.VarChar(500)
  todayContext Json?    @map("today_context")
  dayKey       String   @map("day_key") @db.VarChar(10)   // "2026-03-03" (유니크용)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course       Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId, context, dayKey], name: "unique_user_course_context_day")
  @@index([userId])
  @@index([courseId])
  @@map("recommendation_feedbacks")
}
